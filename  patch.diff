+   // ===== Loop robusto (anti-drift) + economia em background (Opção A) =====
+   let __stopLoop = null;
+
+   function startAccurateLoop(intervalMs) {
+     let active = true;
+     let expected = performance.now() + intervalMs;
+
+     function step() {
+       if (!active) return;
+
+       const now = performance.now();
+       const drift = now - expected;
+       expected += intervalMs;
+
+       try { oLoop(); } catch (e) { Herror("Erro no oLoop:", e); }
+
+       const next = Math.max(0, intervalMs - drift);
+       setTimeout(step, next);
+     }
+
+     setTimeout(step, intervalMs);
+     return () => { active = false; };
+   }
+
+   function restartLoop() {
+     if (__stopLoop) __stopLoop();
+     const interval = document.hidden ? 2500 : 1000; // Opção A
+     __stopLoop = startAccurateLoop(interval);
+   }
+
+   restartLoop();
+   document.addEventListener("visibilitychange", restartLoop, { passive: true });
+   window.addEventListener("beforeunload", () => __stopLoop && __stopLoop(), { once: true });
  
